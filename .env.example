# Copy this file to .env and fill in the values.

# A long, random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# PostgreSQL connection string.
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/raion

# --- Phase 1 ---
# Credentials for the single admin user created on first startup.
ADMIN_USERNAME=maharshi
ADMIN_PASSWORD=your-strong-password

# Session lifetime in seconds (default: 7 days = 604800)
# SESSION_TTL_SECONDS=604800

# --- Phase 3+ ---
OPENAI_API_KEY=sk-...

# --- Phase 5+ ---
# Absolute path to the workspace directory the assistant is allowed to touch.
# Defaults to <project_root>/workspace if not set.
# WORKSPACE_DIR=E:\BTP-assistant-workspace

# --- Phase 8+ ---
# Google OAuth client credentials (Desktop app / "Installed application" type).
# Create them at: https://console.cloud.google.com/apis/credentials
# Enable APIs: Gmail API, Google Drive API, Google Calendar API
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
#
# Fernet key for encrypting OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=your-generated-fernet-key

# --- Phase 9 ---
# No new env vars required. Automations use the existing OPENAI_API_KEY,
# WORKSPACE_DIR, and (optionally) Google credentials configured above.

# --- LangSmith (optional) ---
# Sign up at: https://smith.langchain.com and create a project.
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=raion

# WhatsApp (Green API)
GREEN_API_BASE_URL=https://api.green-api.com
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
GREEN_API_WEBHOOK_TOKEN=
