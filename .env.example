# Copy this file to .env and fill in the values.

# A long, random string used to sign session cookies.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# SQLite database path (relative to project root).
# Default: sqlite+aiosqlite:///./app.db
# DATABASE_URL=sqlite+aiosqlite:///./app.db

# --- Phase 1 ---
# Credentials for the single admin user created on first startup.
ADMIN_USERNAME=maharshi
ADMIN_PASSWORD=your-strong-password

# Session lifetime in seconds (default: 7 days = 604800)
# SESSION_TTL_SECONDS=604800

# --- Phase 3+ ---
# OPENAI_API_KEY=sk-...

# --- Phase 5+ ---
# Absolute path to the workspace directory the assistant is allowed to touch.
# WORKSPACE_DIR=E:\BTP-assistant-workspace

# --- Phase 8+ ---
# Google OAuth client credentials (Desktop app type).
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# Fernet key for encrypting OAuth tokens at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# FERNET_KEY=...
